# .env.template — BookwormPRO 环境变量配置
# 
# 复制此文件为 ~/.bookwormpro/.env 并填入你的 API Key
# 至少配置一个 provider 即可使用

# ── DeepSeek（推荐首选，性价比最高）──
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── DashScope / 通义千问（视觉模型 + 图片生成）──
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 视觉模型（可选）──
AUXILIARY_VISION_MODEL=qwen-vl-max

# ── Anthropic / Claude（可选，需中转或原生 API）──
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Google Gemini（可选）──
# GOOGLE_API_KEY=your-google-ai-studio-key

# ── 豆包 Doubao Vision（可选，国内视觉方案）──
# DOUBAO_API_KEY=ark-your-ark-key-here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 微信/企微 消息平台（可选）──
# 需要企业微信/个人微信机器人 ID 和 Token
# WEIXIN_ACCOUNT_ID=your-bot-id@im.bot
# WEIXIN_TOKEN=your-token
# WECOM_BOT_ID=your-wecom-bot-id
# WECOM_SECRET=your-wecom-secret

# ── 浏览器自动化（可选）──
# BROWSERBASE_PROJECT_ID=your-browserbase-project-id
